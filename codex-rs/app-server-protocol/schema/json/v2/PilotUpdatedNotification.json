{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "PilotCycleKind": {
      "enum": [
        "continue",
        "wrapUp"
      ],
      "type": "string"
    },
    "PilotRun": {
      "properties": {
        "activeCycleKind": {
          "anyOf": [
            {
              "$ref": "#/definitions/PilotCycleKind"
            },
            {
              "type": "null"
            }
          ]
        },
        "activeTurnId": {
          "type": [
            "string",
            "null"
          ]
        },
        "deadlineAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "goal": {
          "type": "string"
        },
        "iterationCount": {
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        },
        "lastAgentMessage": {
          "type": [
            "string",
            "null"
          ]
        },
        "lastCycleCompletedAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "lastCycleKind": {
          "anyOf": [
            {
              "$ref": "#/definitions/PilotCycleKind"
            },
            {
              "type": "null"
            }
          ]
        },
        "lastCycleSummary": {
          "type": [
            "string",
            "null"
          ]
        },
        "lastError": {
          "type": [
            "string",
            "null"
          ]
        },
        "lastProgressAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "lastSubmittedTurnId": {
          "type": [
            "string",
            "null"
          ]
        },
        "pendingCycleKind": {
          "anyOf": [
            {
              "$ref": "#/definitions/PilotCycleKind"
            },
            {
              "type": "null"
            }
          ]
        },
        "startedAt": {
          "format": "int64",
          "type": "integer"
        },
        "status": {
          "$ref": "#/definitions/PilotStatus"
        },
        "statusMessage": {
          "type": [
            "string",
            "null"
          ]
        },
        "stopRequestedAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "updatedAt": {
          "format": "int64",
          "type": "integer"
        },
        "wrapUpRequested": {
          "type": "boolean"
        },
        "wrapUpRequestedAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "goal",
        "iterationCount",
        "startedAt",
        "status",
        "updatedAt",
        "wrapUpRequested"
      ],
      "type": "object"
    },
    "PilotStatus": {
      "enum": [
        "running",
        "paused",
        "stopped",
        "completed"
      ],
      "type": "string"
    },
    "PilotUpdateType": {
      "enum": [
        "started",
        "queued",
        "cycleStarted",
        "cycleCompleted",
        "paused",
        "resumed",
        "wrapUpRequested",
        "stopped",
        "completed",
        "failed",
        "updated"
      ],
      "type": "string"
    }
  },
  "properties": {
    "message": {
      "type": [
        "string",
        "null"
      ]
    },
    "run": {
      "anyOf": [
        {
          "$ref": "#/definitions/PilotRun"
        },
        {
          "type": "null"
        }
      ]
    },
    "threadId": {
      "type": "string"
    },
    "updateType": {
      "$ref": "#/definitions/PilotUpdateType"
    }
  },
  "required": [
    "threadId",
    "updateType"
  ],
  "title": "PilotUpdatedNotification",
  "type": "object"
}